{
  "name": "cli-code",
  "displayName": "CLI Code",
  "description": "Launch and switch between AI coding CLIs (Claude, Codex, Gemini, opencode, and more) from a VS Code terminal.",
  "version": "0.1.1",
  "publisher": "x302502",
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#FFB300",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/x302502/cli-code.git"
  },
  "bugs": {
    "url": "https://github.com/x302502/cli-code/issues"
  },
  "keywords": [
    "cli",
    "terminal",
    "ai",
    "claude",
    "coding-agent"
  ],
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cli-code.open",
        "title": "Open CLI",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "cli-code.openNew",
        "title": "Open CLI in new tab",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "cli-code.addFilepath",
        "title": "CLI: Insert At-Mentioned"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "cli-code.openNew",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cli-code.open",
        "title": "Open CLI",
        "key": "cmd+escape",
        "mac": "cmd+escape",
        "win": "ctrl+escape",
        "linux": "ctrl+escape"
      },
      {
        "command": "cli-code.openNew",
        "title": "Open CLI in new tab",
        "key": "cmd+shift+escape",
        "mac": "cmd+shift+escape",
        "win": "ctrl+shift+escape",
        "linux": "ctrl+shift+escape"
      },
      {
        "command": "cli-code.addFilepath",
        "title": "CLI: Insert At-Mentioned",
        "key": "cmd+alt+k",
        "mac": "cmd+alt+k",
        "win": "ctrl+alt+K",
        "linux": "ctrl+alt+K"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun run check-types && bun run lint && bun esbuild.js",
    "watch:esbuild": "bun esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "bun run check-types && bun run lint && bun esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "vsix": "vsce package"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.94.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3"
  },
  "trustedDependencies": [
    "@vscode/vsce-sign"
  ]
}
